# 数据库配置
DB_HOST=localhost
DB_PORT=5432
DB_USER=postgres
DB_PASSWORD=nce_root_123
DB_NAME=nce_db

# Redis配置
REDIS_HOST=localhost
REDIS_PORT=6379

# JWT配置
JWT_SECRET=nce_jwt_secret_key_123

# 环境
NODE_ENV=development

# API基础URL - all proxied through Traefik (use relative paths)
VITE_ACCOUNT_API_URL=/api
VITE_CASHFLOW_API_URL=
VITE_CONTENT_API_URL=
VITE_DATA_API_URL=/dp

# Traefik
TRAEFIK_INSECURE=true
TRAEFIK_USER=admin
TRAEFIK_PASS_HASH=
ACME_EMAIL=admin@neurocashengine.com

# Generate Traefik password hash:
#   docker run traefik:v3.3 htpasswd -nb admin your_password 2>/dev/null | cut -d: -f2
